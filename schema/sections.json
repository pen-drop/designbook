{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Product Sections",
    "description": "Schema for defining product sections/roadmap items",
    "type": "array",
    "items": {
        "type": "object",
        "required": [
            "id",
            "title",
            "description",
            "status"
        ],
        "properties": {
            "id": {
                "type": "string",
                "pattern": "^[a-z0-9-]+$",
                "description": "Unique kebab-case identifier for the section"
            },
            "title": {
                "type": "string",
                "description": "Display title of the section"
            },
            "description": {
                "type": "string",
                "description": "Detailed description of the section's purpose and scope"
            },
            "status": {
                "type": "string",
                "enum": [
                    "proposed",
                    "planned",
                    "in-progress",
                    "done"
                ],
                "default": "planned",
                "description": "Current status of the section"
            },
            "order": {
                "type": "number",
                "description": "Optional sort order"
            }
        }
    }
}