{
  "name": "test_integration_drupal",
  "private": true,
  "workspaces": [
    "packages/*",
    "packages/integrations/*"
  ],

  "type": "module",
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.81",
    "glob": "^11.0.1",
    "js-yaml": "^4.1.1",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "promptfoo": "^0.120.24"
  },
  "dependencies": {
    "storybook-addon-designbook": "workspace:*"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "test:prompt": "npx promptfoo eval -c promptfoo.yaml",
    "dev": "pnpm --filter storybook-addon-designbook clean && pnpm --filter storybook-addon-designbook build && export DESIGNBOOK_HOME=$(pwd)/workspaces/drupal && pnpm --filter storybook-addon-designbook run cli storybook start --force",
    "dev:addon": "pnpm --filter storybook-addon-designbook build:watch",
    "dev:integration:drupal": "pnpm --filter test-integration-drupal storybook",
    "check": "run-s typecheck lint test",
    "typecheck": "pnpm --filter storybook-addon-designbook typecheck",
    "lint": "pnpm --filter storybook-addon-designbook lint",
    "lint:css": "pnpm --filter test-integration-drupal run lint:css",
    "lint:css:fix": "pnpm --filter test-integration-drupal run lint:css:fix"
  },
  "packageManager": "pnpm@9.1.0",
  "pnpm": {
    "overrides": {
      "json-schema-faker": "0.5.9",
      "vite-plugin-twing-drupal": "1.1.2"
    }
  }
}