{
  "name": "daisy_cms_daisyui",
  "private": true,
  "workspaces": [
    "packages/*",
    "packages/integrations/*"
  ],
  "type": "module",
  "devDependencies": {
    "prettier": "^3.5.3"
  },
  "scripts": {
    "build": "pnpm run build --workspaces",
    "test": "pnpm run test --workspaces",
    "storybook": "pnpm --filter test-integration-drupal run storybook",
    "build-storybook": "pnpm --filter test-integration-drupal run build-storybook",
    "dev": "pnpm --filter test-integration-drupal run dev",
    "lint:css": "pnpm --filter test-integration-drupal run lint:css",
    "lint:css:fix": "pnpm --filter test-integration-drupal run lint:css:fix"
  },
  "packageManager": "pnpm@9.1.0"
}