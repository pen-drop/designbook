  "breakpoints": [
    {
      "token": "sm",
      "min_width": "640px",
      "changes": [
        "header: hamburger menu collapses primary navigation",
        "header: logo reduces to short/mark form (leando_short_logo.png)",
        "header: BIBB funding bar wraps label text or hides secondary line",
        "footer: newsletter form stacks email input above submit button",
        "footer: funding-logos row wraps to 2 columns",
        "footer: legal links stack vertically"
      ]
    },
    {
      "token": "xl",
      "min_width": "1280px",
      "changes": [
        "header: full horizontal navigation visible (Suche, Über uns, Anmelden) with hamburger menu",
        "header: full word-mark logo (leando_logo.png)",
        "header: BIBB funding bar on one line with full sponsor text",
        "footer: newsletter form is inline — email input + submit button on one row",
        "footer: funding-logos row horizontal with all sponsor marks visible",
        "footer: social icons and legal links horizontal"
      ]
    }
  ],
