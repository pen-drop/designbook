{#
/**
 * @file
 * Template for feature-card component.
 *
 * Available variables:
 * - icon: Material icon name
 * - title: Card title
 * - description: Card description text
 */
#}
<div{{ attributes.addClass(['rounded-lg', 'border', 'border-outline-variant', 'bg-surface-container', 'p-6', 'text-center']) }}>
  {% if icon %}
    <span class="material-symbols-outlined text-primary text-3xl mb-4 block">{{ icon }}</span>
  {% endif %}
  {% if title %}
    <h3 class="text-2xl font-heading font-semibold leading-[1.3] text-on-surface mb-2">{{ title }}</h3>
  {% endif %}
  {% if description %}
    <p class="text-base font-body leading-relaxed text-on-surface-variant">{{ description }}</p>
  {% endif %}
</div>
