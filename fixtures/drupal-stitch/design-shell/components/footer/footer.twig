{#
/**
 * @file
 * Template for footer component.
 *
 * Available variables:
 * - copyright: Copyright text
 * - brand: Logo or brand area
 * - navigation: Footer navigation component
 */
#}
<footer{{ attributes.addClass(["border-t", "border-outline-variant/20", "bg-background", "py-20", "px-8"]) }}>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-16 max-w-7xl mx-auto">
    <div class="space-y-6">
      {% if brand %}
        <div class="flex items-center gap-2">
          {{ brand }}
        </div>
      {% endif %}

      {% if copyright %}
        <p class="text-sm text-on-surface-variant max-w-xs leading-relaxed">
          {{ copyright }}
        </p>
      {% endif %}
    </div>

    {% if navigation %}
      <div class="flex flex-wrap gap-16 justify-start md:justify-end">
        {{ navigation }}
      </div>
    {% endif %}
  </div>
</footer>
