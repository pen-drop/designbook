{#
/**
 * @file
 * Template for cta-block component.
 *
 * Available variables:
 * - heading: CTA heading text
 * - description: Optional description
 * - actions: Action buttons slot
 */
#}
<div{{ attributes.addClass(['text-center', 'py-8']) }}>
  {% if heading %}
    <h2 class="text-4xl md:text-5xl font-heading font-bold leading-[1.1] tracking-[-0.03em] text-on-surface mb-4">{{ heading }}</h2>
  {% endif %}
  {% if description %}
    <p class="text-base font-body leading-relaxed text-on-surface-variant max-w-xl mx-auto mb-8">{{ description }}</p>
  {% endif %}
  {% if actions %}
    <div class="flex items-center justify-center gap-4">
      {{ actions }}
    </div>
  {% endif %}
</div>
