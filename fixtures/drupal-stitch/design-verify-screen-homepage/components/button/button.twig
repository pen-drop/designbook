{#
/**
 * @file
 * Template for button component.
 *
 * Available variables:
 * - variant: Button variant (primary, secondary)
 * - label: Button text
 * - url: Optional link URL
 */
#}
{% set variant = variant|default('primary') %}

{% set variant_classes = {
  'primary': 'bg-primary text-on-surface shadow-[0_0_20px_rgba(0,112,243,0.3)] hover:bg-primary/90 active:scale-95',
  'secondary': 'bg-transparent border border-on-surface/10 text-on-surface hover:bg-on-surface/5',
} %}

{% set base_classes = ['inline-flex', 'items-center', 'justify-center', 'px-8', 'py-3', 'rounded', 'font-label', 'text-sm', 'font-bold', 'transition-all'] %}

{% if url %}
<a{{ attributes.addClass(base_classes).addClass(variant_classes[variant]|default('')) }} href="{{ url }}">
  {{ label }}
</a>
{% else %}
<button{{ attributes.addClass(base_classes).addClass(variant_classes[variant]|default('')) }} type="button">
  {{ label }}
</button>
{% endif %}
