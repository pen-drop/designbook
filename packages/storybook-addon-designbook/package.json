{
  "name": "storybook-addon-designbook",
  "version": "0.0.0",
  "description": "Storybook addon for Designbook integration",
  "keywords": [
    "storybook-addon"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/storybookjs/storybook-addon-kit"
  },
  "license": "MIT",
  "author": "Designbook Team",
  "type": "module",
  "bin": {
    "storybook-addon-designbook": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./preview": {
      "types": "./dist/preview.d.ts",
      "default": "./dist/preview.js"
    },
    "./preset": "./dist/preset.js",
    "./config": {
      "types": "./dist/config.d.ts",
      "require": "./dist/config.cjs",
      "default": "./dist/config.js"
    },
    "./manager": "./dist/manager.js",
    "./manager-helpers": "./dist/manager-helpers.js",
    "./vitest-plugin-sdc": {
      "types": "./dist/vitest-plugin-sdc.d.ts",
      "default": "./dist/vitest-plugin-sdc.js"
    },
    "./dist/*": "./dist/*",
    "./package.json": "./package.json"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "*.js",
    "*.d.ts"
  ],
  "scripts": {
    "clean": "node -e \"fs.rmSync('./dist', { recursive: true, force: true })\"",
    "prebuild": "pnpm run clean",
    "build": "tsup",
    "build:watch": "tsup --watch",
    "eject-ts": "zx scripts/eject-typescript.js",
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "lint:fix": "pnpm lint --fix",
    "prerelease": "zx scripts/prepublish-checks.js",
    "release": "npm run build && auto shipit",
    "start": "run-p build:watch \"storybook --quiet\"",
    "storybook": "storybook dev -p 6006",
    "test": "vitest run"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@storybook/addon-docs": "^10.0.0",
    "@storybook/icons": "^2.0.0",
    "@storybook/react-vite": "^10.0.0",
    "@types/glob": "^9.0.0",
    "@types/node": "^20",
    "@types/react": "^18.2.65",
    "@types/react-dom": "^18.2.21",
    "@vitejs/plugin-react": "^4.7.0",
    "auto": "^11.3.0",
    "boxen": "^8.0.1",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-storybook": "^10.0.0",
    "glob": "^11.0.1",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.6.2",
    "prompts": "^2.4.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "storybook": "^10.0.0",
    "ts-dedent": "^2.2.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.44.1",
    "vite": "^7.0.5",
    "vitest": "^4.0.18",
    "zx": "^8.7.1"
  },
  "peerDependencies": {
    "storybook": "*",
    "@storybook/addon-vitest": "*",
    "vitest": "*"
  },
  "peerDependenciesMeta": {
    "@storybook/addon-vitest": {
      "optional": true
    },
    "vitest": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "bundler": {
    "managerEntries": [
      "src/manager.tsx",
      "src/manager-helpers.tsx"
    ],
    "previewEntries": [
      "src/preview.ts",
      "src/index.ts"
    ],
    "nodeEntries": [
      "src/preset.ts",
      "src/config.ts"
    ]
  },
  "storybook": {
    "displayName": "Designbook",
    "supportedFrameworks": [
      "html"
    ],
    "icon": "https://user-images.githubusercontent.com/321738/63501763-88dbf600-c4cc-11e9-96cd-94adadc2fd72.png"
  },
  "dependencies": {
    "ajv": "^8.18.0",
    "ajv-draft-04": "^1.0.0",
    "commander": "^14.0.3",
    "jsonata": "^2.1.0",
    "marked": "^17.0.2",
    "yaml": "^2.8.2"
  }
}