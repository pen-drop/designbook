{
  "name": "storybook-addon-designbook",
  "version": "0.3.0",
  "description": "Storybook addon and CLI for Designbook — AI workflows that structure your design for CMS implementation",
  "keywords": [
    "storybook-addon",
    "design-system",
    "designbook",
    "cms",
    "ai-workflows"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pen-drop/designbook.git",
    "directory": "packages/storybook-addon-designbook"
  },
  "homepage": "https://github.com/pen-drop/designbook#readme",
  "bugs": {
    "url": "https://github.com/pen-drop/designbook/issues"
  },
  "license": "MIT",
  "author": "Designbook Team",
  "type": "module",
  "bin": {
    "storybook-addon-designbook": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./preview": {
      "types": "./dist/preview.d.ts",
      "default": "./dist/preview.js"
    },
    "./renderer": {
      "types": "./dist/renderer-browser.d.ts",
      "default": "./dist/renderer-browser.js"
    },
    "./preset": "./dist/preset.js",
    "./config": {
      "types": "./dist/config.d.ts",
      "require": "./dist/config.cjs",
      "default": "./dist/config.js"
    },
    "./manager": "./dist/manager.js",
    "./manager-helpers": "./dist/manager-helpers.js",
    "./vitest-plugin-sdc": {
      "types": "./dist/vitest-plugin-sdc.d.ts",
      "default": "./dist/vitest-plugin-sdc.js"
    },
    "./dist/*": "./dist/*",
    "./package.json": "./package.json"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "manager.js",
    "preset.js",
    "preview.js"
  ],
  "scripts": {
    "cli": "node dist/cli.js",
    "clean": "node -e \"fs.rmSync('./dist', { recursive: true, force: true })\"",
    "prebuild": "pnpm run clean",
    "build": "tsup",
    "build:watch": "tsup --watch",
    "eject-ts": "zx scripts/eject-typescript.js",
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "lint:fix": "pnpm lint --fix",
    "prerelease": "zx scripts/prepublish-checks.js",
    "release": "npm run build && auto shipit",
    "start": "run-p build:watch \"storybook --quiet\"",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@storybook/addon-docs": "^10.0.0",
    "@storybook/icons": "^2.0.0",
    "@storybook/react-vite": "^10.0.0",
    "@types/glob": "^9.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^20",
    "@types/react": "^18.2.65",
    "@types/react-dom": "^18.2.21",
    "@vitejs/plugin-react": "^4.7.0",
    "auto": "^11.3.0",
    "boxen": "^8.0.1",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-storybook": "^10.0.0",
    "glob": "^11.0.1",
    "globals": "^17.4.0",
    "jsdom": "^29.1.1",
    "npm-run-all2": "^8.0.4",
    "playwright": "^1.58.2",
    "prettier": "^3.6.2",
    "prompts": "^2.4.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "storybook": "^10.0.0",
    "ts-dedent": "^2.2.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.44.1",
    "vite": "^7.0.5",
    "vitest": "^4.0.18",
    "zx": "^8.7.1"
  },
  "peerDependencies": {
    "playwright": "^1.58.2",
    "storybook": "*",
    "vite": "^5.0.0 || ^6.0.0 || ^7.0.0"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "bundler": {
    "managerEntries": [
      "src/manager.tsx",
      "src/manager-helpers.tsx"
    ],
    "previewEntries": [
      "src/preview.ts",
      "src/index.ts",
      "src/renderer-browser.ts"
    ],
    "nodeEntries": [
      "src/preset.ts",
      "src/config.ts"
    ]
  },
  "storybook": {
    "displayName": "Designbook",
    "supportedFrameworks": [
      "html"
    ]
  },
  "dependencies": {
    "@ark-ui/react": "^5.35.0",
    "@storybook/addon-themes": "^10.0.0",
    "@storybook/icons": "^2.0.0",
    "ajv": "^8.18.0",
    "ajv-draft-04": "^1.0.0",
    "commander": "^14.0.3",
    "front-matter": "^4.0.2",
    "js-yaml": "^4.1.1",
    "jsonata": "^2.1.0",
    "marked": "^17.0.2",
    "minimatch": "^10.2.4",
    "odiff-bin": "^4.3.2",
    "semver": "^7.6.0",
    "yaml": "^2.4.0"
  }
}
