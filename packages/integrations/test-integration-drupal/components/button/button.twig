{#
/**
 * @file
 * Template for Button component (Leando design).
 *
 * Available variables:
 * - label: Button text label
 * - variant: Button style variant (primary, secondary, tertiary, etc.)
 * - type: HTML button type (button, submit, reset)
 * - url: Link URL (renders as anchor if provided)
 * - disabled: Whether button is disabled
 * - active: Whether button is in active state
 * - external_link: Whether link opens in new tab
 * - full_width: Whether button takes full width
 * - icon: Icon to display
 * - prefix: Content before label
 * - suffix: Content after label
 */
#}
{% set base_classes = [
  'component',
  'btn',
  'leando-button',
  'copy-m',
  variant|default('primary'),
  full_width ? 'w-full' : '',
  active ? 'active' : '',
] %}

{% set variant_styles = variant|default('primary') %}

{% if url %}
  {# Render as link #}
  <a
    href="{{ url }}"
    {{ external_link ? 'target="_blank" rel="noopener noreferrer"' : '' }}
    class="{{ base_classes|join(' ') }}"
    {{ attributes }}
    {{ disabled ? 'aria-disabled="true"' : '' }}
  >
    {% if prefix %}
      <span class="btn__prefix">{{ prefix }}</span>
    {% endif %}
    {% if icon %}
      <span class="btn__icon button-icon">{{ icon }}</span>
    {% endif %}
    {% if label %}
      <span class="btn__label">{{ label }}</span>
    {% endif %}
    {% if suffix %}
      <span class="btn__suffix">{{ suffix }}</span>
    {% endif %}
  </a>
{% else %}
  {# Render as button #}
  <button
    type="{{ type|default('button') }}"
    class="{{ base_classes|join(' ') }}"
    {{ attributes }}
    {{ disabled ? 'disabled' : '' }}
  >
    {% if prefix %}
      <span class="btn__prefix">{{ prefix }}</span>
    {% endif %}
    {% if icon %}
      <span class="btn__icon button-icon">{{ icon }}</span>
    {% endif %}
    {% if label %}
      <span class="btn__label">{{ label }}</span>
    {% endif %}
    {% if suffix %}
      <span class="btn__suffix">{{ suffix }}</span>
    {% endif %}
  </button>
{% endif %}

{# Leando Button Styles #}
<style>
  .leando-button {
    display: flex;
    height: 48px;
    padding: 10px 24px;
    justify-content: center;
    align-items: center;
    border-radius: 24px;
    text-decoration: none;
    gap: 8px;
  }

  /* Primary Button */
  .leando-button.primary {
    background-color: var(--color-darkgreen);
    color: var(--color-white);
    border: none;
  }

  .leando-button.primary:hover {
    background-color: var(--color-green);
    box-shadow: 0 0 20px 0 rgba(0, 0, 0, 0.3);
  }

  /* Secondary Button */
  .leando-button.secondary {
    background-color: var(--color-white);
    color: var(--color-darkgreen);
    border: 1px solid var(--color-darkgreen);
    height: 100%;
  }

  .leando-button.secondary:hover {
    background-color: var(--color-green);
    color: var(--color-white);
    box-shadow: 0 0 20px 0 rgba(0, 0, 0, 0.3);
  }

  /* Secondary No Border */
  .leando-button.secondary-noborder {
    background-color: var(--color-white);
    color: var(--color-darkgreen);
    border: none;
    height: 100%;
  }

  .leando-button.secondary-noborder:hover {
    background-color: var(--color-green);
    color: var(--color-white);
    box-shadow: 0 0 20px 0 rgba(0, 0, 0, 0.3);
  }

  /* Secondary Cookies */
  .leando-button.secondary-cookies {
    background-color: var(--color-white);
    color: var(--color-darkgreen);
    border: none;
    height: 36px;
    padding: 20px 45px;
    margin: 0 5px;
  }

  .leando-button.secondary-cookies:hover {
    background-color: var(--color-green);
    color: var(--color-white);
    box-shadow: 0 0 20px 0 rgba(0, 0, 0, 0.3);
  }

  /* Negative Cookies */
  .leando-button.negative-cookies {
    background-color: rgba(255, 255, 255, 0.709);
    color: var(--color-black);
    border: none;
    height: 36px;
    padding: 20px 45px;
    margin: 0 5px;
  }

  .leando-button.negative-cookies:hover {
    background-color: var(--color-white);
    box-shadow: 0 0 20px 0 rgba(0, 0, 0, 0.3);
  }

  /* Tertiary Button */
  .leando-button.tertiary {
    width: 100%;
    min-height: 48px;
    background-color: rgb(206, 206, 206);
    color: var(--color-black);
    border: none;
  }

  .leando-button.tertiary:hover {
    background-color: var(--color-black);
    color: rgb(206, 206, 206);
  }

  /* Blue Tab Button */
  .leando-button.blue {
    height: 100%;
    padding: 8px 24px;
    padding-block: 16px;
    font-size: large;
    border-radius: 0;
    border: none;
    border-bottom: 4px solid var(--color-mediumblue);
    background-color: var(--color-mediumblue);
    color: var(--color-lightgray);
  }

  .leando-button.blue:hover,
  .leando-button.blue.active {
    border-bottom: 4px solid var(--color-white);
  }

  /* Gray Tab Button */
  .leando-button.gray {
    height: 100%;
    padding: 8px 24px;
    padding-block: 16px;
    font-size: large;
    border-radius: 0;
    border: none;
    border-bottom: 4px solid var(--color-lightgray);
    background-color: var(--color-lightgray);
    color: var(--color-black);
  }

  .leando-button.gray:hover,
  .leando-button.gray.active {
    border-bottom: 4px solid var(--color-white);
  }

  /* Search Button */
  .leando-button.search {
    background-color: var(--color-darkgreen);
    color: var(--color-white);
    border: none;
    outline: none;
    border-radius: 0 24px 24px 0;
  }

  .leando-button.search svg {
    width: 24px;
    height: 24px;
  }

  /* Card Button */
  .leando-button.card {
    padding: 5px;
    margin: 5px;
    color: var(--color-darkgreen);
    flex-wrap: nowrap;
    border-radius: 8px;
    text-align: left;
    cursor: pointer;
    font-size: 14px;
    border: 1px solid var(--color-lightgray);
    background-color: transparent;
    height: auto;
  }

  .leando-button.card:hover,
  .leando-button.card.active {
    text-decoration-line: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 4px;
    background-color: transparent;
  }

  /* Disabled State */
  .leando-button:disabled,
  .leando-button[aria-disabled="true"] {
    opacity: 0.6;
    cursor: not-allowed;
    pointer-events: none;
  }

  /* Icon Styles */
  .btn__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .btn__icon svg {
    width: 20px;
    height: 20px;
  }
</style>
