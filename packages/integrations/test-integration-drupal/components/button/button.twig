{#
/**
 * @file
 * Template for Button component.
 *
 * Available variables:
 * - variant: Choose button style (default, outline)
 * - text: The clickable label
 */
#}
{% set classes = [
  'component',
  'button',
  variant ? 'button--' ~ variant : 'button--default',
] %}

<button{{ attributes.addClass(classes) }}>
  {% if text %}
    <span class="button__text">
      {{ text }}
    </span>
  {% endif %}
</button>
