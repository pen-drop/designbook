{#
/**
 * @file
 * Template for button component.
 *
 * Available variables:
 * - text: The button label.
 * - href: URL the button links to.
 * - variant: Visual variant of the button.
 */
#}
{% set variant_class = variant ? 'btn-' ~ variant : '' %}
{% set classes = [
  'component',
  'button',
  'btn',
  variant_class,
] %}

{% if href %}
  <a{{ attributes.addClass(classes) }} href="{{ href }}">{{ text }}</a>
{% else %}
  <button{{ attributes.addClass(classes) }}>{{ text }}</button>
{% endif %}
