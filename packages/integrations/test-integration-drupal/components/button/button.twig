{#
/**
 * @file
 * Button component template
 * 
 * Available slots:
 * - text: The button text content
 * 
 * Available props:
 * - variant: Button style variant (e.g., 'default', 'outline')
 * - state: Button state (e.g., 'enabled', 'disabled')
 * 
 * Generated by: pendrop-orchestrate-full-component
 * Uses Figma design tokens and custom component classes
 */
#}

{%
  set classes = [
    'button',
    variant ? 'button-' ~ variant : 'button-default',
    'inline-flex',
    'items-center',
    'justify-center',
    'p-[var(--spacing-3)]',
    'gap-[var(--spacing-2)]',
    'rounded-[var(--border-radius-rounded-lg)]',
    'font-normal',
    'text-base',
    'transition-all',
    'duration-200',
    state == 'disabled' ? 'bg-base-200 text-base-content opacity-[var(--opacity-opacity-70)] cursor-not-allowed' : (variant == 'default' ? 'bg-primary text-primary-content hover:opacity-90 active:scale-95' : ''),
    state != 'disabled' and variant == 'outline' ? 'border-2 border-primary text-primary bg-transparent hover:bg-primary hover:text-primary-content' : '',
  ]
%}

{% set attributes = attributes.addClass(classes) %}

{# Handle disabled state #}
{% if state and state == 'disabled' %}
  {% set attributes = attributes.setAttribute('disabled', 'disabled') %}
{% endif %}

<button{{ attributes }}>
  {{ text }}
</button>
