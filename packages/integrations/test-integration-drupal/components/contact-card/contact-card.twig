{#
/**
 * @file
 * ContactPerson component — matches Figma ContactPerson component set.
 * Desktop: 187px round image + text. Mobile: 70px image + smaller text.
 * Supports default/small sizes and light/dark modes.
 */
#}
{% set variant = variant|default('default') %}
{% set darkmode = darkmode|default(false) %}
{% set text_color = darkmode ? 'text-[#FAFAED]' : 'text-base-content' %}

{% set classes = [
  'component',
  'contact-card',
  'contact-card--' ~ variant,
  'flex',
  'items-center',
  text_color,
] %}

{% if variant == 'small' %}

<div{{ attributes.addClass(classes).addClass('gap-4') }}>
  {% if image_url %}
    <div class="w-[70px] h-[70px] lg:w-[100px] lg:h-[100px] rounded-full bg-accent overflow-hidden flex-shrink-0">
      <img src="{{ image_url }}" alt="{{ image_alt|default('') }}" class="w-full h-full object-cover" />
    </div>
  {% endif %}
  <div class="flex flex-col">
    {% if name %}
      <span class="text-[16px] leading-[22px] lg:text-[20px] lg:leading-[27px] font-bold">{{ name }}</span>
    {% endif %}
    {% if position %}
      <span class="text-[16px] leading-[22px] lg:text-[20px] lg:leading-[27px] font-medium">{{ position }}</span>
    {% endif %}
  </div>
</div>

{% else %}

<div{{ attributes.addClass(classes).addClass('gap-6 flex-col md:flex-row') }}>
  {% if image_url %}
    <div class="w-[70px] h-[70px] lg:w-[187px] lg:h-[187px] rounded-full bg-accent overflow-hidden flex-shrink-0">
      <img src="{{ image_url }}" alt="{{ image_alt|default('') }}" class="w-full h-full object-cover" />
    </div>
  {% endif %}
  <div class="flex flex-col gap-0.5">
    {% if name %}
      <span class="text-[16px] leading-[22px] lg:text-[20px] lg:leading-[27px] font-bold">{{ name }}</span>
    {% endif %}
    {% if position %}
      <span class="text-[16px] leading-[22px] lg:text-[20px] lg:leading-[27px] font-medium">{{ position }}</span>
    {% endif %}
    {% if email %}
      <a href="mailto:{{ email }}" class="text-[16px] leading-[22px] lg:text-[20px] lg:leading-[27px] font-medium hover:underline {{ text_color }}">{{ email }}</a>
    {% endif %}
    {% if phone %}
      <a href="tel:{{ phone }}" class="text-[16px] leading-[22px] lg:text-[20px] lg:leading-[27px] font-medium hover:underline {{ text_color }}">{{ phone }}</a>
    {% endif %}
  </div>
</div>

{% endif %}
