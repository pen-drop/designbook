{# hero--landing.twig #}
<section{{ attributes.addClass(['hero', 'hero--landing']) }}{% if background_color %} style="background-color: {{ background_color }}"{% endif %}>
  <div class="hero__inner">
    <div class="hero__content">
      <h1 class="hero__title">{{ title }}</h1>
      {% if subtitle %}
        <p class="hero__subtitle">{{ subtitle }}</p>
      {% endif %}
      {% if actions %}
        <div class="hero__actions">{{ actions }}</div>
      {% endif %}
    </div>
    {% if media %}
      <div class="hero__media">{{ media }}</div>
    {% endif %}
  </div>
</section>
