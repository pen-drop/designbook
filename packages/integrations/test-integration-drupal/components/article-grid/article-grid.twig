{#
/**
 * @file
 * Template for article-grid component.
 *
 * Available variables:
 * - items: Article card components to display in the grid.
 */
#}
{% set classes = [
  'component',
  'article-grid',
  'grid',
  'grid-cols-1',
  'md:grid-cols-2',
  'lg:grid-cols-3',
  'gap-6',
] %}

<div{{ attributes.addClass(classes) }}>
  {{ items }}
</div>
