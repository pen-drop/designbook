{#
/**
 * @file
 * Layout component with explicit grid column support.
 */
#}
{% set columns = columns|default(1) %}
{% set container = container|default('md') %}

{% set col_class = {
  1: 'grid-cols-1',
  2: 'grid-cols-1 md:grid-cols-2',
  3: 'grid-cols-1 md:grid-cols-2 lg:grid-cols-3',
  4: 'grid-cols-1 md:grid-cols-2 lg:grid-cols-4',
} %}

{% set container_class = {
  'sm': 'max-w-screen-sm mx-auto px-4',
  'md': 'max-w-screen-lg mx-auto px-4 lg:px-8',
  'lg': 'max-w-screen-xl mx-auto px-4 lg:px-8',
  'full': 'w-full',
} %}

<div class="layout py-12 lg:py-16">
  <div class="{{ container_class[container]|default('max-w-screen-lg mx-auto px-4 lg:px-8') }}">
    {% if items is iterable %}
      <div class="grid {{ col_class[columns]|default('grid-cols-1') }} gap-6">
        {% for item in items %}
          {{ item }}
        {% endfor %}
      </div>
    {% elseif items %}
      {{ items }}
    {% endif %}
  </div>
</div>
