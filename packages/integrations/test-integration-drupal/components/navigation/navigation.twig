{#
/**
 * @file
 * Template for navigation component.
 */
#}
{% set variant = variant|default('primary') %}

{% if variant == 'footer' %}
  {% include 'navigation--footer.twig' with {
    attributes: attributes,
    items: items,
  } only %}
{% else %}
  {% include 'navigation--primary.twig' with {
    attributes: attributes,
    items: items,
  } only %}
{% endif %}
