{#
/**
 * @file
 * Template for nav-footer component.
 *
 * Available variables:
 * - items: Footer navigation items.
 */
#}
{% set classes = [
  'component',
  'nav-footer',
] %}

<nav{{ attributes.addClass(classes) }}>
  <ul class="nav-footer__list menu menu-horizontal">
    {{ items }}
  </ul>
</nav>
