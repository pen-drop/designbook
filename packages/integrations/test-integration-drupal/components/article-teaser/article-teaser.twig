{#
/**
 * @file
 * Template for article-teaser component.
 *
 * Available variables:
 * - title: Article title
 * - preheadline: Category or topic label
 * - image_src: Teaser image URL
 * - image_alt: Alt text for teaser image
 * - url: Link to the full article
 * - button_text: Read more button label
 * - button_color: Button color variant (swimsuit, ocean, sun)
 */
#}
{% set classes = [
  'component',
  'article-teaser',
] %}

<article{{ attributes.addClass(classes) }}>
  {% if image_src %}
    <div class="article-teaser__image">
      <a href="{{ url }}">
        <img src="{{ image_src }}" alt="{{ image_alt|default('') }}" loading="lazy" />
      </a>
    </div>
  {% endif %}
  <div class="article-teaser__content">
    {% if preheadline %}
      <span class="article-teaser__preheadline">{{ preheadline }}</span>
    {% endif %}
    {% if title %}
      <h3 class="article-teaser__title">
        <a href="{{ url }}">{{ title }}</a>
      </h3>
    {% endif %}
    {% if button_text %}
      <a href="{{ url }}" class="article-teaser__button article-teaser__button--{{ button_color|default('swimsuit') }}">
        {{ button_text|default('Lesen') }}
      </a>
    {% endif %}
  </div>
</article>
