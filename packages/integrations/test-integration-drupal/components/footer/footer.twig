{#
/**
 * @file
 * Footer — dark background (primary/ocean) per Figma.
 */
#}
{% set classes = [
  'component',
  'footer',
  'bg-primary',
  'text-primary-content',
  'p-8',
  'lg:p-16',
] %}

<footer{{ attributes.addClass(classes) }}>
  <div class="flex flex-col md:flex-row items-center justify-between gap-4 w-full">
    <nav class="footer__nav">{{ navigation }}</nav>
    <div class="footer__copyright opacity-70">{{ copyright }}</div>
  </div>
</footer>
