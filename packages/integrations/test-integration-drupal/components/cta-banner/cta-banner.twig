{#
/**
 * @file
 * Template for cta-banner component.
 *
 * Available variables:
 * - headline: Banner headline text
 * - text: Supporting text below the headline
 * - button_label: CTA button text
 * - button_url: CTA button link
 * - variant: Color variant (ocean, swimsuit, sun)
 */
#}
{% set classes = [
  'component',
  'cta-banner',
  variant ? 'cta-banner--' ~ variant : 'cta-banner--ocean',
] %}

<div{{ attributes.addClass(classes) }}>
  <div class="cta-banner__content">
    {% if headline %}
      <h2 class="cta-banner__headline">{{ headline }}</h2>
    {% endif %}
    {% if text %}
      <p class="cta-banner__text">{{ text }}</p>
    {% endif %}
    {% if button_label %}
      <a href="{{ button_url|default('/kontakt') }}" class="cta-banner__button">
        {{ button_label }}
      </a>
    {% endif %}
  </div>
</div>
