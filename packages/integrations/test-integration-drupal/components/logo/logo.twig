{#
/**
 * @file
 * Template for logo component.
 *
 * Available variables:
 * - src: URL of the logo image.
 * - alt: Alternative text for the logo.
 * - href: URL the logo links to.
 */
#}
{% set classes = [
  'component',
  'logo',
] %}

<a{{ attributes.addClass(classes) }} href="{{ href }}">
  <img src="{{ src }}" alt="{{ alt }}" class="logo__image" />
</a>
