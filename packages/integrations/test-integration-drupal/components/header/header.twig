{#
/**
 * @file
 * Header — 72px height, 120px horizontal padding per Figma.
 * Variants: default (no border), scroll (2px bottom border).
 */
#}
{% set variant = variant|default('default') %}

{% set classes = [
  'component',
  'header',
  'navbar',
  'bg-base-100',
  'h-[72px]',
  'px-[120px]',
  'py-4',
  'flex',
  'justify-between',
  'items-center',
  variant == 'scroll' ? 'border-b-2 border-neutral' : '',
] %}

<header{{ attributes.addClass(classes) }}>
  <div class="header__logo flex-none">{{ logo }}</div>
  <nav class="header__navigation hidden lg:flex items-center">{{ navigation }}</nav>
</header>
