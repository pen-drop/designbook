{% set classes = [
  'component',
  'card',
  'card--vertical',
  'card',
  'bg-base-200',
  'group',
  'transition-transform',
  'duration-300',
  'ease-in-out',
] %}

<div{{ attributes.addClass(classes) }}>
  {% if media %}
    <figure class="card__media overflow-hidden">{{ media }}</figure>
  {% endif %}
  <div class="card-body">
    {% if preheadline %}
      <span class="text-[15px] leading-[20px] font-medium text-secondary uppercase tracking-wider">{{ preheadline }}</span>
    {% endif %}
    {% if title %}
      <h3 class="card-title text-[24px] leading-[32px] font-medium">{{ title }}</h3>
    {% endif %}
    {% if description %}
      <p class="text-[20px] leading-[27px] font-medium text-base-content/70">{{ description }}</p>
    {% endif %}
    {% if actions %}
      <div class="card-actions justify-start mt-2">{{ actions }}</div>
    {% endif %}
  </div>
</div>
