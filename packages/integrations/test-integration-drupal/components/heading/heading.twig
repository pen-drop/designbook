{#
/**
 * @file
 * Heading component — Satoshi type scale from Figma.
 */
#}
{% set level = level|default('h2') %}
{% set classes = [
  'component',
  'heading',
  'col-span-full',
] %}

{% set type_classes = {
  'h1': 'text-[35px] leading-[41px] lg:text-[60px] lg:leading-[74px] font-bold tracking-[1px]',
  'h2': 'text-[30px] leading-[36px] lg:text-[48px] lg:leading-[58px] font-bold',
  'h3': 'text-[23px] leading-[32px] lg:text-[36px] lg:leading-[49px] font-medium',
  'h4': 'text-[20px] leading-[27px] lg:text-[24px] lg:leading-[32px] font-medium tracking-[1px]',
} %}

<div{{ attributes.addClass(classes) }}>
  {% if preheadline %}
    <span class="heading__preheadline text-[15px] leading-[20px] font-medium text-primary uppercase tracking-wider block mb-2">{{ preheadline }}</span>
  {% endif %}
  <{{ level }} class="heading__text {{ type_classes[level]|default(type_classes['h2']) }}">
    {{ text }}
  </{{ level }}>
</div>
