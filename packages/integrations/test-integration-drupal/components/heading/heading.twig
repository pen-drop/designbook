{#
/**
 * @file
 * Template for heading component.
 *
 * Available variables:
 * - text: The heading text content.
 * - html_tag: The HTML heading level (h1-h6).
 * - variant: Visual variant of the heading.
 */
#}
{% set tag = html_tag|default('h2') %}
{% set classes = [
  'component',
  'heading',
  variant ? 'heading--' ~ variant : 'heading--default',
] %}

<{{ tag }}{{ attributes.addClass(classes) }}>{{ text }}</{{ tag }}>
